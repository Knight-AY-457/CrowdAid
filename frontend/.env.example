# ─── CrowdAid Frontend Environment Variables ────────────────────────────────
# Copy this to .env.local and fill in your values

# API base URL (must include /api suffix)
# Local (with Vite proxy): /api
# Vercel production example: https://your-render-backend.onrender.com/api
VITE_API_BASE_URL=/api

# App metadata
VITE_APP_NAME=CrowdAid
VITE_APP_VERSION=1.0.0
