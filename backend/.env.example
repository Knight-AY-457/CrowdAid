# Database - paste the URI from Supabase "Connect" page
DATABASE_URI=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# JWT auth
JWT_SECRET=change-me-to-a-very-long-random-secret-key-at-least-32-chars

# CORS - frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin account (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=+919000000000